---
interface Props {
  date: Date;
}

const { date } = Astro.props;

if (!date) {
  console.warn('FormattedDate: date is missing');
  return null;
}

const d = new Date(date);
---

<time datetime={date.toISOString()}>
  {
    date.toLocaleDateString('en-us', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  }
</time>
