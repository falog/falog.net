---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const categoryGroups = {
  cpu: ['cpu', 'riscv', 'os'],
  web: ['web'],
  languages: ['english', 'russian'],
  falkoe: ['falkoe'],
  wazzefalradio: ['wazzefalradio'],
  others: ['others', 'daily', 'blog'],
} as const;

const categoryLabels = {
  cpu: 'CPU / RISC-V / OS自作',
  web: 'Web開発',
  languages: '英語・言語学習',
  falkoe: 'Falkoe(ふぁるこえ)',
  wazzefalradio: '方言をエンタメとして楽しむ「わっぜふぁるらじ(YouTube)」',
  others: 'その他 日常的なブログなど',
};

const posts = await getCollection('blog');

function getPostsByCategory(key: keyof typeof categoryGroups) {
  return posts
    .filter((p) =>
      (categoryGroups[key] as readonly string[]).includes(p.data.category),
    )
    .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
    .slice(0, 3);
}

const order: (keyof typeof categoryGroups)[] = [
  'cpu',
  'web',
  'languages',
  'falkoe',
  'wazzefalradio',
  'others',
];
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>ふぁろぐねっと</h1>

      <p>
        CPU / RISC-VやOS、Web開発、英語・言語学習を題材に、
        仕組みを構造から理解したいエンジニアのための記録ブログ
      </p>

      <!-- カテゴリ導線 -->
      <h2>カテゴリ</h2>

      {
        order.map((key) => {
          const list = getPostsByCategory(key);

          return (
            <section>
              <h3>
                <a href={`/category/${key}`}>{categoryLabels[key]}</a>
              </h3>

              <ul>
                {list.map((post) => (
                  <li>
                    <a href={`/blog/${post.id}`}>{post.data.title}</a>
                  </li>
                ))}
              </ul>

              <p>
                <a href={`/category/${key}`}>→ もっと見る</a>
              </p>
            </section>
          );
        })
      }

      <p>
        → <a href="/blog">記事一覧はこちら</a>
      </p>

      <!-- ここから元の文章（下に移動） -->
      <h2>このブログについて</h2>

      <p>
        CPU、OS自作やソフトウェア開発をしながら、
        発音・ピッチアクセント・方言などの音声も分析する個人技術ブログです。
      </p>

      <p>
        コンピュータと言語を「構造」として理解することをテーマに、
        試行錯誤の過程を記録しています。
      </p>

      <h2>このブログで扱うテーマ</h2>
      <ul>
        <li>RISC-V / CPU自作 / OS開発</li>
        <li>発音・ピッチアクセント・方言の音声分析</li>
        <li>
          英語などの言語学習・発音練習の記録（発音・音声の構造理解を中心に）
        </li>
        <li>Web / 組み込み / 回路設計の技術ログ</li>
        <li>個人開発や制作の記録</li>
        <li>試行錯誤や失敗も含めた思考ログ</li>
      </ul>

      <p class="philosophy">
        「完成した成果」よりも、<br />
        「考えた過程」を残すことを目的にしています。
      </p>

      <p class="note">
        学習や開発は、うまくいった部分よりも、<br />
        つまずいた点や試行錯誤の方が、後から見返したときに価値があると考えています。
      </p>

      <p class="note">
        このブログは未来の自分のための記録であり、<br />
        同じように悩んだり遠回りしている人のヒントになれば、という気持ちで書いています。
      </p>

      <p class="note">
        内容は整理されたノウハウというよりも、<br />
        途中経過や未完成な考えも含めてそのまま残しています。
      </p>
    </main>

    <Footer />
  </body>
</html>
