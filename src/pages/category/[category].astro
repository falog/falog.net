---
import { getCollection } from 'astro:content';
import { categoryGroups } from '../../utils/category';

type CategoryKey = keyof typeof categoryGroups;

export async function getStaticPaths() {
  return Object.keys(categoryGroups).map((c) => ({
    params: { category: c },
  }));
}

const { category } = Astro.params as { category: CategoryKey };

const posts = await getCollection('blog');

const currentCategories = categoryGroups[category] as readonly string[];

const filtered = posts.filter((p) =>
  currentCategories.includes(p.data.category),
);

// 表示ラベル
const categoryLabels = {
  cpu: 'CPU / RISC-V',
  web: 'Web開発',
  english: '英語・言語学習',
};

// カテゴリ説明
const categoryDescriptions = {
  cpu: 'RISC-Vを目標にCPUを自作する過程や設計をまとめています',
  web: 'P2PなどのWeb開発の記録です',
  english: '発音や音声分析を中心とした言語学習の記録です',
};

// 不正なカテゴリ対策（念のため）
if (!categoryGroups[category]) {
  throw new Error(`Unknown category: ${category}`);
}
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{categoryLabels[category]}</title>
  </head>
  <body>
    <main>
      <h1>{categoryLabels[category]}</h1>

      <p>{categoryDescriptions[category]}</p>

      <p>{filtered.length}件の記事</p>

      <ul>
        {
          filtered.map((post) => (
            <li>
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
              <small>
                （{new Date(post.data.pubDate).toLocaleDateString()}）
              </small>
            </li>
          ))
        }
      </ul>

      <p><a href="/">← トップに戻る</a></p>
    </main>
  </body>
</html>
